{
  "expo": {
    "name": "MyMoneyApp",
    "slug": "MyMoneyApp",
    "scheme": "mymoneyapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3EAD8"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F3EAD8"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "My Money",
      "shortName": "My Money",
      "lang": "th",
      "themeColor": "#C49650",
      "backgroundColor": "#F3EAD8",
      "display": "standalone",
      "orientation": "portrait",
      "description": "Personal finance tracker",
      "startUrl": "/"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-splash-screen",
      "expo-font"
    ]
  }
}
